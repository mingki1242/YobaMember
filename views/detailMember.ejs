<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>요바나시 멤버 상세정보</title>
</head>
<body>
<div align="center">
    <h2><%=member.name%>에 대한 상세 정보 입니다</h2>
    <h3><%=member.name%> 직원 정보</h3>
    <hr>

    <form method = "post" action="/modify">
        <input type="hidden" name = "id" value="<%=member.id%>" > <p></p>
        이름 : <input type="text" name = "name" value="<%=member.name%>" > <p></p>
        이메일 : <input type="text" value="<%=member.email%>" name = "email"><p></p>
        비밀번호 : <input type="text" value="<%=member.password%>" name = "password"><p></p>
        직책 : <input type="text" value="<%=member.position%>" name = "position"><p></p>
        시급 : <input type="text" value="<%=member.money%>" name = "money"><p></p>
        <input type="submit" value="수정하기">
    </form><p></p>
    조회 수 : <%=member.readcnt%><p></p>
    <a href="/" >[뒤로 가기]</a>
    <a href="/delete/<%=member.id%>">[직원 삭제]</a>
</div>



</body>
</html>